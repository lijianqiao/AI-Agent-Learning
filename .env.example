# ── LLM 运行模式 ────────────────────────────────────────────────────
# local: Ollama 本地模型，默认 qwen3:4b，不产生费用
# cloud: DeepSeek / GPT / Gemini 等云端 API
LLM_MODE=local

# ── local 模式：Ollama ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# ── cloud 模式：DeepSeek / OpenAI 兼容 API ──────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key
BASE_URL=https://api.deepseek.com/v1
# 若使用 OpenAI / 其他兼容接口，可配置 OPENAI_API_KEY